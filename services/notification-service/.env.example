APP_NAME=AngelowNotification
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8008

APP_LOCALE=es
APP_FALLBACK_LOCALE=es
APP_FAKER_LOCALE=es_CO

APP_MAINTENANCE_DRIVER=file

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=pgsql
DB_HOST=notification-db
DB_PORT=5432
DB_DATABASE=angelow_notifications
DB_USERNAME=postgres
DB_PASSWORD=root
DB_SCHEMA=public

LEGACY_DB_HOST=host.docker.internal
LEGACY_DB_PORT=3306
LEGACY_DB_DATABASE=angelow
LEGACY_DB_USERNAME=root
LEGACY_DB_PASSWORD=

BROADCAST_CONNECTION=log
QUEUE_CONNECTION=redis
CACHE_STORE=redis
CACHE_PREFIX=angelow_notification

REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379
REDIS_DB=5
REDIS_CACHE_DB=5
