APP_NAME=AngelowOrder
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8004

APP_LOCALE=es
APP_FALLBACK_LOCALE=es
APP_FAKER_LOCALE=es_CO

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=pgsql
DB_HOST=order-db
DB_PORT=5432
DB_DATABASE=angelow_orders
DB_USERNAME=postgres
DB_PASSWORD=root
DB_SCHEMA=public

LEGACY_DB_HOST=host.docker.internal
LEGACY_DB_PORT=3306
LEGACY_DB_DATABASE=angelow
LEGACY_DB_USERNAME=root
LEGACY_DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis

CACHE_STORE=redis
CACHE_PREFIX=angelow_order

REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379
REDIS_DB=1
REDIS_CACHE_DB=1

MAIL_MAILER=log
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="noreply@angelow.com"
MAIL_FROM_NAME="${APP_NAME}"

FRONTEND_URL=http://localhost:5173
NOTIFICATION_SERVICE_URL=http://notification-service:8000/api
NOTIFICATION_ORDER_TYPE_ID=1
CATALOG_SERVICE_URL=http://catalog-service:8000/api
ORDER_REFUND_TEAM_EMAIL=
CATALOG_VARIANT_PATH=/internal/variants
CATALOG_INVENTORY_COMMIT_PATH=/internal/inventory/commit
ORDER_STOCK_RESERVATION_TTL=7200
ORDER_STOCK_LOCK_SECONDS=10
ORDER_STOCK_RECONCILIATION_BATCH_SIZE=200
ORDER_STOCK_RESERVATION_EXTEND_ON_CONFIRMATION=1800
ORDER_STOCK_WS_CHANNEL=ws:orders:stock
